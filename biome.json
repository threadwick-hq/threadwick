{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": { "ignoreUnknown": true, "includes": ["**", "!apps/web/**", "!apps/studio/**"] },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noExplicitAny": "error",
				"noVar": "error"
			},
			"style": {
				"useConst": "error",
				"noParameterAssign": "error",
				"useNodejsImportProtocol": "error",
				"noCommonJs": "error",
				"noEnum": "error",
				"useNamingConvention": {
					"level": "error",
					"options": { "strictCase": false }
				},
				"useFilenamingConvention": {
					"level": "error",
					"options": { "filenameCases": ["kebab-case", "export"] }
				},
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"paths": {
							"express": "Use Hono (default) or Fastify for new work."
						}
					}
				}
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": { "maxAllowedComplexity": 15 }
				}
			}
		}
	},
	"assist": {
		"actions": {
			"source": { "organizeImports": "on" }
		}
	}
}
