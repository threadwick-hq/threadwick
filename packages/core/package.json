{
	"name": "@threadwick/core",
	"version": "0.2.0",
	"description": "Threadwick's design-system foundation: design tokens (OKLCH, light + dark), the brand wordmark, and shared UI primitives (shadcn-style, on Radix).",
	"type": "module",
	"license": "AGPL-3.0-or-later",
	"sideEffects": [
		"**/*.css"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/threadwick-hq/core.git"
	},
	"exports": {
		".": "./src/index.ts",
		"./tokens": "./src/tokens/index.ts",
		"./brand": "./src/brand/index.ts",
		"./components": "./src/components/index.ts",
		"./tokens.css": "./src/tokens/tokens.css",
		"./theme.css": "./src/styles/theme.css",
		"./lib/utils": "./src/lib/utils.ts",
		"./capabilities": "./src/capabilities.ts"
	},
	"scripts": {
		"build:tokens": "tsx scripts/build-tokens.ts && biome check --write src/tokens/palette.ts src/tokens/tokens.ts src/tokens/tokens.css figma/variables.json",
		"gen:brand-glyphs": "tsx scripts/gen-brand-glyphs.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"validate": "tsx scripts/validate.ts",
		"check:contrast": "tsx scripts/check-contrast.ts",
		"check": "npm run build:tokens && npm run typecheck && npm run lint && npm run check:contrast && npm run validate",
		"test": "vitest run"
	},
	"peerDependencies": {
		"react": "^18"
	},
	"optionalDependencies": {
		"@fortawesome/pro-regular-svg-icons": "^7.2.0"
	},
	"devDependencies": {
		"@types/node": "^20.14.0",
		"@types/react": "^18.3.12",
		"react": "^18.3.1",
		"tailwindcss": "^4.3.1",
		"tsx": "^4.19.2",
		"typescript": "~5.6.3",
		"vitest": "^3.2.6"
	},
	"dependencies": {
		"@radix-ui/react-accordion": "^1.2.14",
		"@radix-ui/react-alert-dialog": "^1.1.17",
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-dropdown-menu": "^2.1.18",
		"@radix-ui/react-label": "^2.1.10",
		"@radix-ui/react-popover": "^1.1.19",
		"@radix-ui/react-select": "^2.3.1",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-switch": "^1.3.1",
		"@radix-ui/react-toggle-group": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@threadwick/icons": "workspace:*",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"react-aria-components": "^1.19.0",
		"tailwind-merge": "^3.6.0"
	}
}
