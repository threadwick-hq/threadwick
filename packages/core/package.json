{
  "name": "@threadwick/core",
  "version": "0.2.0",
  "description": "Threadwick's design-system foundation: design tokens (OKLCH, light + dark), the Ant Design theme, the brand wordmark, and shared UI primitives (Stack).",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "repository": { "type": "git", "url": "https://github.com/threadwick-hq/core.git" },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./tokens": { "types": "./dist/tokens/index.d.ts", "import": "./dist/tokens/index.js" },
    "./theme": { "types": "./dist/theme/index.d.ts", "import": "./dist/theme/index.js" },
    "./brand": { "types": "./dist/brand/index.d.ts", "import": "./dist/brand/index.js" },
    "./components": { "types": "./dist/components/index.d.ts", "import": "./dist/components/index.js" },
    "./tokens.css": "./dist/tokens.css"
  },
  "scripts": {
    "build:tokens": "tsx scripts/build-tokens.ts",
    "prebuild": "tsx scripts/build-tokens.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "validate": "tsx scripts/validate.ts",
    "check:contrast": "tsx scripts/check-contrast.ts",
    "check": "npm run build:tokens && npm run typecheck && npm run lint && npm run check:contrast && npm run validate"
  },
  "peerDependencies": {
    "react": "^18",
    "antd": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "antd": "^5.22.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.18.2"
  }
}
