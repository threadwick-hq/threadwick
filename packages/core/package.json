{
	"name": "@threadwick/core",
	"version": "0.2.0",
	"description": "Threadwick's design-system foundation: design tokens (OKLCH, light + dark), the Ant Design theme, the brand wordmark, and shared UI primitives (Stack).",
	"type": "module",
	"license": "AGPL-3.0-or-later",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/threadwick-hq/core.git"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./tokens": {
			"types": "./dist/tokens/index.d.ts",
			"import": "./dist/tokens/index.js"
		},
		"./brand": {
			"types": "./dist/brand/index.d.ts",
			"import": "./dist/brand/index.js"
		},
		"./components": {
			"types": "./dist/components/index.d.ts",
			"import": "./dist/components/index.js"
		},
		"./tokens.css": "./dist/tokens.css",
		"./theme.css": "./dist/theme.css",
		"./lib/utils": {
			"types": "./dist/lib/utils.d.ts",
			"import": "./dist/lib/utils.js"
		},
		"./capabilities": {
			"types": "./dist/capabilities.d.ts",
			"import": "./dist/capabilities.js"
		}
	},
	"scripts": {
		"build:tokens": "tsx scripts/build-tokens.ts && biome check --write src/tokens/palette.ts src/tokens/tokens.ts src/tokens/tokens.css figma/variables.json",
		"gen:brand-glyphs": "tsx scripts/gen-brand-glyphs.ts",
		"prebuild": "npm run build:tokens",
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"validate": "tsx scripts/validate.ts",
		"check:contrast": "tsx scripts/check-contrast.ts",
		"check": "npm run build:tokens && npm run typecheck && npm run lint && npm run check:contrast && npm run validate",
		"test": "vitest run"
	},
	"peerDependencies": {
		"react": "^18"
	},
	"optionalDependencies": {
		"@fortawesome/pro-regular-svg-icons": "^7.2.0"
	},
	"devDependencies": {
		"@types/node": "^20.14.0",
		"@types/react": "^18.3.12",
		"react": "^18.3.1",
		"tailwindcss": "^4.3.1",
		"tsup": "^8.3.5",
		"tsx": "^4.19.2",
		"typescript": "~5.6.3",
		"vitest": "^3.2.6"
	},
	"dependencies": {
		"@radix-ui/react-accordion": "^1.2.14",
		"@radix-ui/react-alert-dialog": "^1.1.17",
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-dropdown-menu": "^2.1.18",
		"@radix-ui/react-label": "^2.1.10",
		"@radix-ui/react-select": "^2.3.1",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-switch": "^1.3.1",
		"@radix-ui/react-toggle-group": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@threadwick/icons": "workspace:*",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"react-aria-components": "^1.19.0",
		"tailwind-merge": "^3.6.0"
	}
}
