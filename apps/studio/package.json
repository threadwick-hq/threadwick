{
  "name": "threadwick-studio",
  "version": "1.0.0",
  "description": "threadwick studio — a crochet project designer. Design granny-square stitch charts the way you crochet them.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "predev": "tsx scripts/gen-favicon.mjs",
    "gen:favicon": "tsx scripts/gen-favicon.mjs",
    "build": "npm run gen:favicon && tsc --noEmit && eslint . && vite build",
    "preview": "vite preview --host --port 8080",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "keywords": [
    "crochet",
    "granny-square",
    "chart",
    "svg",
    "pattern",
    "designer",
    "react",
    "typescript"
  ],
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@supabase/supabase-js": "^2.107.0",
    "@threadwick/core": "workspace:*",
    "@threadwick/editor": "workspace:*",
    "@threadwick/icons": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.80.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
