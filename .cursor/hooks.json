{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-start.sh",
        "timeout": 30
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/work-index-reminder.sh",
        "matcher": "Write|Edit",
        "timeout": 60
      }
    ]
  }
}
