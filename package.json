{
  "name": "threadwick-studio",
  "version": "1.0.0",
  "description": "threadwick studio — a crochet project designer. Design granny-square stitch charts the way you crochet them.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && eslint . && vite build",
    "preview": "vite preview --host --port 8080",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "keywords": [
    "crochet",
    "granny-square",
    "chart",
    "svg",
    "pattern",
    "designer",
    "antd",
    "react",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "@supabase/supabase-js": "^2.107.0",
    "antd": "^5.22.0",
    "iconoir-react": "^7.11.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
