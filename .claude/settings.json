{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/session-start.sh",
						"timeout": 30
					}
				]
			},
			{
				"matcher": "resume",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/session-start.sh",
						"timeout": 30
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/work-index-reminder.sh",
						"timeout": 60
					}
				]
			}
		]
	}
}
