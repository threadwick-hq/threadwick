{
	"$schema": "https://opencode.ai/config.json",
	"instructions": ["apps/*/AGENTS.md", "packages/*/AGENTS.md"],
	"permission": {
		"edit": "allow",
		"bash": {
			"*": "ask",
			"pnpm *": "allow",
			"npx *": "allow",
			"node *": "allow",
			"tsx *": "allow",
			"git *": "allow",
			"gh *": "allow",
			"git push --force*": "deny",
			"git push *--force*": "deny",
			"git push -f *": "deny",
			"git reset --hard*": "deny",
			"rm -rf *": "deny"
		}
	}
}
