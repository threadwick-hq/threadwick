{
	"$schema": "https://opencode.ai/config.json",
	"instructions": ["apps/*/AGENTS.md", "packages/*/AGENTS.md"],
	"permission": {
		"edit": "allow",
		"bash": {
			"*": "ask",
			"pnpm *": "allow",
			"npx *": "allow",
			"node *": "allow",
			"tsx *": "allow",
			"git *": "allow",
			"gh *": "allow",
			"git*--force*": "deny",
			"git*--force-with-lease*": "allow",
			"git push*+*": "deny",
			"git*--hard*": "deny",
			"*rm -rf*": "deny"
		}
	}
}
